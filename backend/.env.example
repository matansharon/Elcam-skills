# Copy to backend/.env and fill in to enable "✨ Suggest with AI".
# Without a key the feature is inert (the button reports "not configured").
ANTHROPIC_API_KEY=
# Optional: override the analysis model (defaults to claude-sonnet-5).
ANALYSIS_MODEL=claude-sonnet-5

# Activity admin panel (page at /activity). Both required to enable the panel.
ADMIN_PANEL_USER=
ADMIN_PANEL_PASSWORD=
# Optional: cap stored activity rows (oldest trimmed). Blank = keep all.
ACTIVITY_LOG_MAX_ROWS=
